---
import Layout from "@/layouts/Layout.astro";
import siteData from "@/data/global/site.json";
import Hero from "@/components/Hero.astro";
import Pricing from "@/components/Pricing.astro";
import MarketChart from "@/components/MarketChart.astro";
import FeaturedSlider from "@/components/FeaturedSlider.astro";
import Portal from "@/components/Portal.astro";
import Services from "@/components/Services.astro";
import TransactionDesk from "@/components/TransactionDesk.astro";
import Projects from "@/components/Projects.astro";
import AIMastery from "@/components/AIMastery.astro";
import QuickHelpForm from "@/components/QuickHelpForm.astro";
import Footer from "@/components/Footer.astro";
---

<Layout
  title={siteData.name}
  description={siteData.description}
>
  <Hero />
  <!-- <MarketChart /> --> 
  <FeaturedSlider />
  <Portal />
  <Services />
  <TransactionDesk />
  <AIMastery featuredOnly />
  <!--<Pricing /> -->
  <QuickHelpForm />
  <Footer />
</Layout>
