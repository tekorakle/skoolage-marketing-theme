---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import { getCollection, render } from "astro:content";
import { withBase } from "@/lib/assetPath";
import { icons } from "@/lib/icons";

export async function getStaticPaths() {
  const now = new Date();
  const allPosts = await getCollection("posts");
  const posts = import.meta.env.DEV
    ? allPosts
    : allPosts.filter((p) => !p.data.draft && p.data.pubDate <= now);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={post.data.title} description={post.data.description}>
  <div class="px-6 lg:px-12 py-16">
    <div class="max-w-3xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-site-muted font-mono">
          <li>
            <a href={withBase('/')} data-astro-reload class="hover:text-site-text transition-colors">Home</a>
          </li>
          <li class="text-site-border">/</li>
          <li>
            <a href={withBase('/blog')} class="hover:text-site-text transition-colors">Blog</a>
          </li>
          <li class="text-site-border">/</li>
          <li class="text-electric-cyan truncate max-w-48">{post.data.title}</li>
        </ol>
      </nav>

      {post.data.image && (
        <div class="w-full aspect-[21/9] overflow-hidden rounded-2xl mb-8">
          <img
            src={withBase(post.data.image.path)}
            alt={post.data.image.alt}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      )}

      <header class="mb-10">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span
            class="text-xs font-mono font-bold uppercase tracking-wider px-2.5 py-1 rounded-full bg-site-surface border border-site-border/60 text-electric-cyan"
          >
            {post.data.category}
          </span>
          <time datetime={post.data.pubDate.toISOString()} class="text-xs text-site-muted font-mono">
            {formattedDate}
          </time>
        </div>

        <h1 class="font-display font-bold text-4xl sm:text-5xl text-white mb-4 leading-tight">
          {post.data.title}
        </h1>
        <p class="text-site-text-muted text-xl leading-relaxed">{post.data.description}</p>

        {
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-5">
              {post.data.tags.map((tag) => (
                <span class="text-xs font-mono px-2 py-0.5 rounded bg-site-surface border border-site-border/40 text-site-muted">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      <div class="border-t border-site-border/40 pt-10 prose-site">
        <Content />
      </div>

      <div class="mt-12 pt-8 border-t border-site-border/40">
        <a
          href={withBase('/blog')}
          class="inline-flex items-center gap-2 text-sm font-mono text-site-muted hover:text-site-text transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons['arrow-back']} />
          Back to Blog
        </a>
      </div>
    </div>
  </div>
  <Footer />
</Layout>

<style>
  /* Prose styles for rendered Markdown — scoped to this page */
  .prose-site :global(h2) {
    font-family: var(--font-oswald), Impact, sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: white;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }
  .prose-site :global(h3) {
    font-family: var(--font-oswald), Impact, sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    color: white;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-site :global(p) {
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose-site :global(a) {
    color: var(--color-primary-light);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-site :global(a:hover) {
    color: var(--color-primary);
  }
  .prose-site :global(ul),
  .prose-site :global(ol) {
    color: var(--color-text-muted);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.75;
  }
  .prose-site :global(li) {
    margin-bottom: 0.25rem;
  }
  .prose-site :global(ul) {
    list-style-type: disc;
  }
  .prose-site :global(ol) {
    list-style-type: decimal;
  }
  .prose-site :global(code:not(pre code)) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-raised);
    color: var(--color-primary-light);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }
  .prose-site :global(pre) {
    background: var(--bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--color-text);
  }
  .prose-site :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    color: var(--color-text-subtle);
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose-site :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
  .prose-site :global(strong) {
    color: white;
    font-weight: 600;
  }
</style>
