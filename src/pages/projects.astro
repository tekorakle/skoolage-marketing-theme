---
import Layout from "@/layouts/Layout.astro";
import Projects from "@/components/Projects.astro";
import Footer from "@/components/Footer.astro";
import { withBase } from "@/lib/assetPath";
import projectsPageData from "@/data/projects/projects-page.json";
---

<Layout
  title={projectsPageData.pageTitle}
  description={projectsPageData.pageDescription}
>
  <div class="px-0">
    <div class="px-6 lg:px-12 pt-16 pb-4 max-w-7xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-site-muted font-mono">
          <li><a href={withBase('/')} data-astro-reload class="hover:text-white transition-colors">Home</a></li>
          <li class="text-site-border">/</li>
          <li class="text-electric-cyan">Projects</li>
        </ol>
      </nav>
    </div>
    <Projects />
  </div>
  <Footer />
</Layout>
