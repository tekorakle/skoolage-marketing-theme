---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import siteData from "@/data/global/site.json";
import { withBase } from "@/lib/assetPath";
import { icons } from "@/lib/icons";
---

<Layout
  title="404 — Page Not Found"
  description={`The page you're looking for doesn't exist. ${siteData.name}.`}
>
  <div class="px-6 lg:px-12 py-24">
    <div class="max-w-2xl mx-auto text-center">

      <!-- Terminal-style error block -->
      <div class="inline-block p-6 rounded-2xl border border-site-border bg-site-surface/40 mb-10 font-mono text-left w-full">
        <div class="flex items-center gap-2 mb-4">
          <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">─</span>
          <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">□</span>
          <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">×</span>
          <span class="ml-2 text-xs text-site-muted">bash</span>
        </div>
        <div class="space-y-1.5 text-sm">
          <p class="text-site-muted">$ <span class="text-site-text">curl {Astro.url.pathname}</span></p>
          <p class="text-red-400">curl: (22) The requested URL returned error: 404</p>
          <p class="text-site-muted">$ <span class="text-site-text">echo $?</span></p>
          <p style="color: var(--color-primary);">1</p>
          <p class="text-site-muted animate-pulse">█</p>
        </div>
      </div>

      <h1 class="font-display font-bold text-6xl sm:text-8xl text-white mb-4">404</h1>
      <p class="text-site-text-muted text-xl mb-3">This page doesn't exist.</p>
      <p class="text-site-muted text-sm mb-10">
        The URL might be mistyped, the page may have moved, or it never existed.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={withBase('/')}
          class="flex items-center gap-2 px-6 py-3.5 rounded-xl bg-cta-gradient text-white font-semibold shadow-glow-sm hover:shadow-glow-md transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons['home-outline']} />
          Go Home
        </a>
        <a
          href={withBase('/contact')}
          class="flex items-center gap-2 px-6 py-3.5 rounded-xl border border-site-border/60 bg-site-surface/30 text-site-text hover:border-electric-blue/30 transition-colors font-semibold"
        >
          Contact Us
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons['arrow-right']} />
        </a>
      </div>

    </div>
  </div>
  <Footer />
</Layout>
