---
import Layout from '../layouts/Layout.astro';
import personalData from '@/data/global/personal.json';
import { withBase } from '../lib/assetPath';

const currentYear = new Date().getFullYear();
const title = `Terms of Service | ${personalData.name}`;
---

<Layout title={title} description={`Terms of service for ${personalData.name}'s portfolio website.`}>
  <main id="main-content" class="policy-page">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl py-24">
      <a href={withBase('/')} class="back-link">← Back to portfolio</a>

      <h1 class="text-3xl sm:text-4xl font-bold mt-8 mb-2 gradient-text">Terms of Service</h1>
      <p class="text-slate-500 text-sm mb-12">Last updated: January {currentYear}</p>

      <div class="prose-section">
        <h2>1. Acceptance of Terms</h2>
        <p>
          By accessing and using this website, you accept and agree to be bound by these Terms of Service.
          If you do not agree to these terms, please do not use this website.
        </p>

        <h2>2. Use of Website</h2>
        <p>
          This website is a personal portfolio. You may view and share content for informational and
          non-commercial purposes. You may not reproduce, redistribute, or commercially exploit any content
          without prior written permission.
        </p>

        <h2>3. Intellectual Property</h2>
        <p>
          All content on this website — including text, code samples, images, and design — is the property
          of {personalData.name} unless otherwise noted. Open-source projects linked from this site are
          governed by their respective licenses.
        </p>

        <h2>4. Contact Form</h2>
        <p>
          Submissions via the contact form are used solely to respond to your inquiry. By submitting the
          form you agree to be contacted at the email address you provide.
        </p>

        <h2>5. External Links</h2>
        <p>
          This site may contain links to external websites. These links are provided for convenience only.
          We have no control over and accept no responsibility for the content of external sites.
        </p>

        <h2>6. Limitation of Liability</h2>
        <p>
          This website is provided "as is" without any representations or warranties. We shall not be
          liable for any loss or damage arising from use of or reliance on information on this site.
        </p>

        <h2>7. Changes</h2>
        <p>
          These terms may be updated at any time. Continued use of the website constitutes acceptance of
          any revised terms.
        </p>

        <h2>8. Contact</h2>
        <p>
          Questions about these terms? Reach out at
          <a href={`mailto:${personalData.email}`}>{personalData.email}</a>.
        </p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .policy-page {
    background-color: var(--bg-base, #040507);
    min-height: 100vh;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-dim, #4a5568);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--color-primary, #8DC63F); }

  .prose-section h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text, #f0f4f8);
    margin: 2rem 0 0.75rem;
  }
  .prose-section p {
    color: var(--color-text-muted, #9aa3ae);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .prose-section a {
    color: var(--color-primary, #8DC63F);
    transition: opacity 0.2s ease;
  }
  .prose-section a:hover { opacity: 0.8; }
</style>
