---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import siteData from "@/data/global/site.json";
import servicesData from "@/data/services/services.json";
import { withBase } from "@/lib/assetPath";

const service = servicesData.find((s) => s.slug === "portfolio-disposition")!;
---

<Layout
  title={service.pageMeta.title}
  description={`${service.pageMeta.description} by ${siteData.name}.`}
>
  <div class="px-6 lg:px-12 py-16">
    <div class="max-w-5xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-site-muted font-mono">
          <li><a href={withBase('/')} data-astro-reload class="hover:text-white transition-colors">Home</a></li>
          <li class="text-site-border">/</li>
          <li><a href={withBase('/services')} class="hover:text-white transition-colors">Services</a></li>
          <li class="text-site-border">/</li>
          <li class={service.theme.accent}>Portfolio Disposition</li>
        </ol>
      </nav>

      <div class="mb-12">
        <div class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full border ${service.theme.badgeBorder} ${service.theme.badgeBg} mb-5`}>
          <span class={`text-xs font-mono font-medium ${service.theme.accent} uppercase tracking-wider`}>{service.intro.badge}</span>
        </div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-white mb-4">{service.intro.heading}</h1>
        <p class="text-site-text-muted text-xl leading-relaxed max-w-3xl">
          {service.intro.subHeading}
        </p>
      </div>

      <!-- Exit value trend visual -->
      <div class="mb-12 rounded-2xl border border-site-border bg-navy-800/80 overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 bg-navy-950/60 border-b border-site-border">
          <div class="flex items-center gap-1.5">
            <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">─</span>
            <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">□</span>
            <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">×</span>
          </div>
          <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-site-muted hidden sm:block">
            Deal Pipeline — Exit Tracking
          </div>
          <div class="flex items-center gap-2 font-mono text-xs" style="color: var(--color-primary);">
            <span class="h-1.5 w-1.5 rounded-full animate-pulse" style="background: var(--color-primary);"></span>
            ACTIVE
          </div>
        </div>

        <div class="px-8 py-10 flex items-center justify-center bg-navy-950/30">
          <svg viewBox="0 0 580 148" width="100%" style="max-width: 640px; height: 148px;" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Grid -->
            <line x1="52" y1="8" x2="52" y2="108" stroke="rgba(80,100,140,0.25)" stroke-width="1"/>
            <line x1="52" y1="108" x2="528" y2="108" stroke="rgba(80,100,140,0.25)" stroke-width="1"/>
            <line x1="52" y1="70" x2="528" y2="70" stroke="rgba(80,100,140,0.08)" stroke-width="1" stroke-dasharray="4,4"/>
            <line x1="52" y1="36" x2="528" y2="36" stroke="rgba(80,100,140,0.08)" stroke-width="1" stroke-dasharray="4,4"/>

            <!-- Area under curve -->
            <polygon points="52,92 148,80 264,64 376,42 500,20 528,14 528,108 52,108" style="fill: var(--color-primary);" opacity="0">
              <animate attributeName="opacity" values="0;0;0.05;0.05;0" keyTimes="0;0.46;0.5;0.87;1" dur="6.5s" repeatCount="indefinite"/>
            </polygon>

            <!-- Trend line draws left to right -->
            <polyline points="52,92 148,80 264,64 376,42 500,20 528,14" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="560" style="stroke: var(--color-primary); opacity: 0.8;">
              <animate attributeName="stroke-dashoffset" values="560;0;0;560" keyTimes="0;0.5;0.87;1" dur="6.5s" repeatCount="indefinite"/>
            </polyline>

            <!-- Data point dots appear as line passes -->
            <circle cx="52" cy="92" r="4.5" style="fill: var(--color-primary);" opacity="0.55"/>
            <circle cx="148" cy="80" r="4.5" style="fill: var(--color-primary);" opacity="0">
              <animate attributeName="opacity" values="0;0;0.55;0.55;0" keyTimes="0;0.13;0.15;0.87;1" dur="6.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="264" cy="64" r="4.5" style="fill: var(--color-primary);" opacity="0">
              <animate attributeName="opacity" values="0;0;0.55;0.55;0" keyTimes="0;0.29;0.31;0.87;1" dur="6.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="376" cy="42" r="4.5" style="fill: var(--color-primary);" opacity="0">
              <animate attributeName="opacity" values="0;0;0.55;0.55;0" keyTimes="0;0.39;0.41;0.87;1" dur="6.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="500" cy="20" r="4.5" style="fill: var(--color-primary);" opacity="0">
              <animate attributeName="opacity" values="0;0;0.55;0.55;0" keyTimes="0;0.47;0.49;0.87;1" dur="6.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="528" cy="14" r="5.5" style="fill: var(--color-primary);" opacity="0">
              <animate attributeName="opacity" values="0;0;0.9;0.9;0" keyTimes="0;0.49;0.5;0.87;1" dur="6.5s" repeatCount="indefinite"/>
            </circle>

            <!-- Axis labels -->
            <text x="52" y="124" text-anchor="middle" fill="rgba(120,140,170,0.6)" font-family="monospace" font-size="8.5">HOLD Y1</text>
            <text x="148" y="124" text-anchor="middle" fill="rgba(120,140,170,0.6)" font-family="monospace" font-size="8.5">Y2</text>
            <text x="264" y="124" text-anchor="middle" fill="rgba(120,140,170,0.6)" font-family="monospace" font-size="8.5">Y3</text>
            <text x="376" y="124" text-anchor="middle" fill="rgba(120,140,170,0.6)" font-family="monospace" font-size="8.5">Y4</text>
            <text x="500" y="124" text-anchor="middle" fill="rgba(120,140,170,0.6)" font-family="monospace" font-size="8.5">Y5</text>
            <text x="528" y="124" text-anchor="middle" font-family="monospace" font-size="8.5" style="fill: var(--color-primary);" opacity="0">EXIT<animate attributeName="opacity" values="0;0;0.9;0.9;0" keyTimes="0;0.49;0.5;0.87;1" dur="6.5s" repeatCount="indefinite"/></text>

            <!-- IRR label at exit -->
            <text x="524" y="11" text-anchor="end" font-family="monospace" font-size="9" style="fill: var(--color-primary);" opacity="0">↑ IRR<animate attributeName="opacity" values="0;0;0.8;0.8;0" keyTimes="0;0.49;0.5;0.87;1" dur="6.5s" repeatCount="indefinite"/></text>
          </svg>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
        {service.capabilities.map((cap) => (
          <div class={`p-5 rounded-xl border border-site-border/60 bg-site-surface/30 hover:${service.theme.borderAccent} transition-colors`}>
            <h3 class="font-semibold text-white mb-2">{cap.title}</h3>
            <p class="text-site-muted text-sm leading-relaxed">{cap.description}</p>
          </div>
        ))}
      </div>

      <div class={`p-8 rounded-2xl border ${service.theme.borderAccent} bg-site-surface/40 text-center`}>
        <h2 class="font-display font-bold text-2xl text-white mb-3">{service.cta.heading}</h2>
        <p class="text-site-muted mb-6">{service.cta.body}</p>
        <a href={withBase('/contact')} class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl bg-cta-gradient text-white font-semibold shadow-glow-sm hover:shadow-glow-md transition-all duration-300">
          {service.cta.label}
        </a>
      </div>
    </div>
  </div>
  <Footer />
</Layout>
