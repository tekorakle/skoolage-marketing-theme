---
import siteData from '@/data/global/site.json';
import personalData from '@/data/global/personal.json';
import navigationData from '@/data/global/navigation.json';
import { withBase } from '@/lib/assetPath';
import { navIcons, icons } from '@/lib/icons';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const retroTvGlob = import.meta.glob('/public/images/retro-tv/*.gif', { eager: false });
const gifCount = Object.keys(retroTvGlob).length;

const navItems = navigationData.navItems;

const basePrefix = base.endsWith('/') ? base.slice(0, -1) : base;
const rawPath = Astro.url.pathname.slice(basePrefix.length) || '/';

function isActive(href: string) {
  if (href === '/') return rawPath === '/';
  return rawPath.startsWith(href);
}

const socialLinks = personalData.linkedin
  ? [{ label: "LinkedIn", href: `https://linkedin.com/company/${personalData.linkedin}`, iconKey: 'linkedin' }]
  : [];

const otherSites = navigationData.otherSites ?? [];
---

<!-- Mobile hamburger toggle -->
<button
  id="sidebar-toggle"
  class="fixed top-4 left-4 z-50 lg:hidden flex items-center justify-center w-10 h-10 bg-navy-800 border border-site-border text-site-text hover:border-site-green/50 transition-colors"
  aria-label="Open navigation"
  aria-expanded="false"
  aria-controls="sidebar"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons['bars-3']} />
</button>

<!-- Sidebar -->
<aside
  id="sidebar"
  class="fixed top-0 left-0 z-40 h-screen w-60 xl:w-64 bg-sidebar-gradient shadow-sidebar flex flex-col -translate-x-full lg:translate-x-0 border-r border-site-border"
  aria-label="Primary navigation"
>
  <!-- Welcome bar -->
  <div id="sidebar-welcome" class="bg-navy-800 border-b border-black px-4 py-3 text-center">
    <p class="text-[11px] font-display font-semibold tracking-[3px] uppercase" style="color: var(--color-primary);">
      {navigationData.welcomeText}
    </p>
  </div>

  <!-- Gray band -->
  <div class="site-band sidebar-band"></div>

  <!-- Logo bar -->
  <div id="sidebar-logo-bar" class="bg-navy-800 flex items-center justify-center py-0 border-b border-black" style="height: 80px;">
    <!-- Expanded logo — flex keeps the existing show/hide CSS working; text is absolutely placed -->
    <a href={withBase('/')} data-astro-reload aria-label="Apex Capital Group home" id="sidebar-logo-box" class="sidebar-logo-expanded site-logo-box flex items-center justify-center flex-shrink-0" style="width: 200px; height: 91px; margin-top: 0; margin-bottom: 0; position: relative; overflow: visible;">
      <div id="sidebar-logo-gif" data-base={base} data-gif-count={gifCount} style="position: absolute; inset: 0; opacity: 0; transition: opacity 1.5s ease; background-size: 107% auto; background-position: top left; overflow: hidden;"></div>
      <span id="logo-glitch-wrap" style="position: relative; z-index: 1; display: inline-block; line-height: 1;">
        <span style="font-family: var(--font-logo); font-weight: bold; font-size: 2.5rem; letter-spacing: 3px; text-transform: uppercase; color: white; text-shadow: 0 1px 3px rgba(0,0,0,0.6);">{siteData.logoText}</span>
      </span>
    </a>
    <!-- Collapsed logo — no inline display; global CSS handles show/hide via .sidebar-collapsed -->
    <a href={withBase('/')} data-astro-reload aria-label="Apex Capital Group home" id="sidebar-logo-box-collapsed" class="sidebar-logo-collapsed site-logo-box flex items-center justify-center flex-shrink-0" style="width: 60px; height: 60px; border-width: 1px; position: relative; overflow: visible;">
      <span id="logo-glitch-wrap-collapsed" style="position: relative; z-index: 1; display: inline-block; line-height: 1;">
        <span class="font-display font-light text-white text-xl uppercase" style="text-shadow: 0 1px 3px rgba(0,0,0,0.6);">{siteData.logoShort}</span>
      </span>
    </a>
  </div>

  <!-- Gray band -->
  <div class="site-band sidebar-band"></div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto py-4 px-2 space-y-0.5" aria-label="Main navigation">
    {navItems.map((item) => (
      <div class="sidebar-nav-item">
        {item.children ? (
          <details class="group" open={isActive(item.href)} data-nav-parent data-href={item.href}>
            <summary
              title={item.label}
              class={`flex items-center gap-3 px-3 py-2.5 cursor-pointer select-none list-none transition-all duration-150 border-l-2 ${
                isActive(item.href)
                  ? "border-site-green text-white bg-site-surface"
                  : "border-transparent text-site-muted hover:text-white hover:bg-site-surface"
              }`}
            >
              <span
                class="flex-shrink-0"
                style={isActive(item.href) ? "color: var(--color-primary);" : ""}
                set:html={navIcons[item.iconKey]}
              />
              <span class="font-display font-semibold text-sm tracking-[1.5px] uppercase flex-1 sidebar-label">{item.label}</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4 text-site-muted transition-transform duration-200 group-open:rotate-180 sidebar-label"
                fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
                aria-hidden="true"
                set:html={icons['chevron-down']}
              />
            </summary>
            <div class="mt-0.5 ml-5 pl-4 border-l border-site-border space-y-0">
              {item.children.map((child) => (
                <a
                  href={withBase(child.href)}
                  data-nav-link
                  aria-current={isActive(child.href) ? "page" : undefined}
                  class={`flex items-center gap-2 px-2 py-2 text-xs font-mono transition-all duration-150 ${
                    isActive(child.href)
                      ? "text-white bg-site-surface"
                      : "text-site-muted hover:text-white hover:bg-site-surface/50"
                  }`}
                  style={isActive(child.href) ? "color: var(--color-primary);" : ""}
                >
                  <span class="flex-shrink-0" set:html={navIcons[child.iconKey]} />
                  <span class="sidebar-label">{child.label}</span>
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={withBase(item.href)}
            data-nav-link
            data-astro-reload={item.href === '/' ? '' : undefined}
            title={item.label}
            aria-current={isActive(item.href) ? "page" : undefined}
            class={`flex items-center gap-3 px-3 py-2.5 transition-all duration-150 border-l-2 ${
              isActive(item.href)
                ? "border-site-green text-white bg-site-surface"
                : "border-transparent text-site-muted hover:text-white hover:bg-site-surface"
            }`}
          >
            <span
              class="flex-shrink-0"
              style={isActive(item.href) ? "color: var(--color-primary);" : ""}
              set:html={navIcons[item.iconKey]}
            />
            <span class="font-display font-semibold text-sm tracking-[1.5px] uppercase sidebar-label">{item.label}</span>
          </a>
        )}
      </div>
    ))}

    <!-- Quick Access -->
    <div class="pt-6 sidebar-quick-access">
      <div class="site-band mb-3"></div>
      <p class="px-3 pb-2 text-[9px] font-display font-semibold uppercase tracking-[3px] text-site-muted sidebar-label">Quick Access</p>
      <a
        href={`tel:${siteData.phone}`}
        title={`Call ${siteData.name}`}
        class="flex items-center gap-3 px-3 py-2 text-site-muted hover:text-white hover:bg-site-surface transition-all duration-150"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={icons['phone']} />
        <span class="text-xs font-mono sidebar-label">{siteData.phoneDisplay}</span>
      </a>
      <a
        href={`mailto:${siteData.email}`}
        title={`Email ${siteData.name}`}
        class="flex items-center gap-3 px-3 py-2 text-site-muted hover:text-white hover:bg-site-surface transition-all duration-150"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" set:html={icons['envelope']} />
        <span class="text-xs font-mono sidebar-label">{siteData.email}</span>
      </a>

      {socialLinks.length > 0 && (
        <>
          <div class="site-band mt-4 mb-3"></div>
          <p class="px-3 pb-2 text-[9px] font-display font-semibold uppercase tracking-[3px] text-site-muted sidebar-label">{navigationData.sidebarSocialLabel}</p>
          {socialLinks.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              title={link.label}
              class="flex items-center gap-3 px-3 py-2 text-site-muted hover:text-white hover:bg-site-surface transition-all duration-150"
            >
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[link.iconKey]} />
              <span class="text-xs font-mono sidebar-label">{link.label}</span>
            </a>
          ))}
        </>
      )}

      <!-- Other Sites -->
      <div class="site-band mt-4 mb-3"></div>
      <p class="px-3 pb-2 text-[9px] font-display font-semibold uppercase tracking-[3px] text-site-muted sidebar-label">{navigationData.sidebarOtherSitesLabel}</p>
      {otherSites.map(site => (
        <a
          href={site.href}
          target="_blank"
          rel="noopener noreferrer"
          title={site.label}
          class="flex items-center gap-3 px-3 py-2 text-site-muted hover:text-white hover:bg-site-surface transition-all duration-150"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="1.75" set:html={icons[site.iconKey]} />
          <span class="text-xs font-mono sidebar-label">{site.label}</span>
        </a>
      ))}
    </div>
  </nav>

  <!-- Theme toggle -->
  <div class="border-t border-site-border">
    <button
      id="theme-toggle"
      class="sidebar-theme-btn w-full flex items-center gap-3 px-4 py-3 text-site-muted hover:text-site-green hover:bg-site-surface transition-all duration-150"
      aria-label="Toggle light/dark mode"
    >
      <!-- Sun icon — shown in dark mode (click to go light) -->
      <svg class="theme-icon-sun w-4 h-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons['sun']} />
      <!-- Moon icon — shown in light mode (click to go dark) -->
      <svg class="theme-icon-moon w-4 h-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons['moon']} />
      <span class="sidebar-label text-xs font-mono tracking-[2px] uppercase">
        <span class="theme-icon-sun">Light Mode</span>
        <span class="theme-icon-moon">Dark Mode</span>
      </span>
    </button>
  </div>

  <!-- Collapse control (desktop only) -->
  <div class="hidden lg:block border-t border-site-border">
    <button
      id="sidebar-collapse-btn"
      class="sidebar-collapse-btn w-full flex items-center gap-3 px-4 py-3 text-site-muted hover:text-site-green hover:bg-site-surface transition-all duration-150"
      aria-label="Toggle sidebar"
    >
      <svg class="sidebar-icon-collapse w-4 h-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" set:html={icons['collapse-sidebar']} />
      <svg class="sidebar-icon-expand w-4 h-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" set:html={icons['expand-sidebar']} />
      <span class="sidebar-label text-xs font-mono tracking-[2px] uppercase">Collapse</span>
    </button>
  </div>

  <!-- Bottom CTA -->
  <div class="p-3 border-t border-site-border">
    <a
      href={withBase('/contact')}
      title={navigationData.ctaText}
      class="flex items-center justify-center gap-2 w-full px-4 py-3 text-white font-display font-semibold text-sm tracking-[2px] uppercase shadow-glow-sm hover:shadow-glow-md transition-all duration-300 hover:brightness-110"
      style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);"
    >
      <!-- Help icon (always visible) -->
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icons['help-circle']} />
      <span class="sidebar-label">{navigationData.ctaText}</span>
    </a>
    <p class="text-center text-[9px] text-site-muted mt-3 font-mono tracking-wider sidebar-label">
      &copy; {new Date().getFullYear()} {siteData.legalName}
    </p>
  </div>
</aside>

<!-- Flyout submenu for collapsed nav parents -->
<div id="sidebar-flyout" role="navigation" aria-label="Submenu" aria-hidden="true">
  <div id="sidebar-flyout-inner"></div>
</div>

<style>
  /* Glitch overlay layers — real DOM elements so we can smoothly revert them */
  .logo-glitch-layer {
    position: absolute;
    top: 0;
    left: 0;
    height: 2.5rem;
    color: white;
    background: black;
    overflow: hidden;
    clip-path: inset(0 0 100% 0); /* fully hidden by default */
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    font-family: var(--font-logo), sans-serif;
    font-size: 2.5rem;
    font-weight: bold;
    letter-spacing: 3px;
    text-transform: uppercase;
    line-height: 1;
  }

  .logo-glitch-blue { left: -2px; text-shadow: 1px 0 blue; }
  .logo-glitch-red  { left:  2px; text-shadow: -1px 0 red; }

  /* Animations fire on both the expanded and collapsed wraps */
  #logo-glitch-wrap.glitch-active .logo-glitch-red,
  #logo-glitch-wrap-collapsed.glitch-active .logo-glitch-red {
    animation: logo-fg-noise 5s infinite linear alternate-reverse;
  }
  #logo-glitch-wrap.glitch-active .logo-glitch-blue,
  #logo-glitch-wrap-collapsed.glitch-active .logo-glitch-blue {
    animation: logo-fg-noise-2 8s infinite linear alternate-reverse;
  }

  /* Percentage-based clip-path so slices span the full text height at any font size */
  @keyframes logo-fg-noise {
    0%,  18%        { clip-path: inset(0 0 100% 0); }
    20%             { clip-path: inset(5% 0 58% 0); }
    22%             { clip-path: inset(55% 0 5% 0); }
    24%,  48%       { clip-path: inset(0 0 100% 0); }
    50%             { clip-path: inset(25% 0 40% 0); }
    52%,  78%       { clip-path: inset(0 0 100% 0); }
    80%             { clip-path: inset(68% 0 5% 0); }
    82%,  100%      { clip-path: inset(0 0 100% 0); }
  }

  @keyframes logo-fg-noise-2 {
    0%,  28%        { clip-path: inset(0 0 100% 0); }
    30%             { clip-path: inset(42% 0 22% 0); }
    33%             { clip-path: inset(8% 0 60% 0); }
    36%,  68%       { clip-path: inset(0 0 100% 0); }
    70%             { clip-path: inset(74% 0 5% 0); }
    73%,  100%      { clip-path: inset(0 0 100% 0); }
  }
</style>

<script>
  // ── Gif fade-in after 10 s ──────────────────────────────────────────────────
  const gifDiv = document.getElementById('sidebar-logo-gif') as HTMLElement | null;
  if (gifDiv) {
    const base = gifDiv.dataset.base ?? '/';
    const count = parseInt(gifDiv.dataset.gifCount ?? '0', 10);
    const gifs = Array.from({ length: count }, (_, i) => `${base}images/retro-tv/bgtv_(${i + 1}).gif`);
    const pick = gifs[Math.floor(Math.random() * gifs.length)];
    setTimeout(() => {
      gifDiv.style.backgroundImage = `linear-gradient(rgba(0,0,0,0.82), rgba(0,0,0,0.82)), url('${pick}')`;
      gifDiv.style.opacity = '1';
    }, 10000);
  }

  // ── Proximity glitch ────────────────────────────────────────────────────────
  const logoBox           = document.getElementById('sidebar-logo-box') as HTMLElement | null;
  const logoBoxCollapsed  = document.getElementById('sidebar-logo-box-collapsed') as HTMLElement | null;
  const glitchWrap        = document.getElementById('logo-glitch-wrap') as HTMLElement | null;
  const glitchWrapCollapsed = document.getElementById('logo-glitch-wrap-collapsed') as HTMLElement | null;

  // All glitch layers across both logos — whichever is hidden just won't be visible
  const layers = [
    ...(glitchWrap         ? Array.from(glitchWrap.querySelectorAll<HTMLElement>('.logo-glitch-layer'))         : []),
    ...(glitchWrapCollapsed ? Array.from(glitchWrapCollapsed.querySelectorAll<HTMLElement>('.logo-glitch-layer')) : []),
  ];

  const PROXIMITY_PX = 40;
  let glitching  = false;
  let cleanupTimer: ReturnType<typeof setTimeout> | null = null;
  let rafPending = false;

  function distToBox(mx: number, my: number): number {
    let minDist = Infinity;
    for (const box of [logoBox, logoBoxCollapsed]) {
      if (!box) continue;
      const r  = box.getBoundingClientRect();
      const dx = Math.max(r.left - mx, 0, mx - r.right);
      const dy = Math.max(r.top  - my, 0, my - r.bottom);
      minDist  = Math.min(minDist, Math.sqrt(dx * dx + dy * dy));
    }
    return minDist;
  }

  const allWraps = [glitchWrap, glitchWrapCollapsed].filter(Boolean) as HTMLElement[];

  function startGlitch() {
    if (glitching) return;
    glitching = true;
    if (cleanupTimer) { clearTimeout(cleanupTimer); cleanupTimer = null; }
    layers.forEach(el => { el.style.clipPath = ''; el.style.transition = ''; });
    allWraps.forEach(w => w.classList.add('glitch-active'));
  }

  function stopGlitch() {
    if (!glitching) return;
    glitching = false;
    if (cleanupTimer) { clearTimeout(cleanupTimer); cleanupTimer = null; }

    layers.forEach(el => {
      el.style.clipPath = window.getComputedStyle(el).clipPath;
    });
    allWraps.forEach(w => w.classList.remove('glitch-active'));

    void document.body.offsetHeight;
    layers.forEach(el => {
      el.style.transition = 'clip-path 0.35s ease';
      el.style.clipPath   = 'inset(0 0 100% 0)';
    });

    cleanupTimer = setTimeout(() => {
      layers.forEach(el => { el.style.clipPath = ''; el.style.transition = ''; });
      cleanupTimer = null;
    }, 400);
  }

  document.addEventListener('mousemove', (e: MouseEvent) => {
    if (rafPending) return;
    rafPending = true;
    requestAnimationFrame(() => {
      rafPending = false;
      if (distToBox(e.clientX, e.clientY) <= PROXIMITY_PX) {
        startGlitch();
      } else {
        stopGlitch();
      }
    });
  });
</script>
