---  
import pricingData from '@/data/pricing.json';  
import { icons } from '@/lib/icons';  
import { withBase } from '@/lib/assetPath';  
---  
  
<div class="site-band"></div>  
  
<section id="pricing" class="py-16 lg:py-24 relative" style="background: var(--bg-deep);">  
  <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgb(var(--primary-ch) / 0.05) 1px, transparent 1px); background-size: 28px 28px;"></div>  
    
  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 lg:px-12">  
    <!-- Section header -->  
    <div class="flex items-center gap-3 mb-3">  
      <div class="h-px w-8" style="background: var(--color-primary);"></div>  
      <span class="text-xs font-mono font-semibold tracking-[3px] uppercase" style="color: var(--color-primary);">{pricingData.sectionLabel}</span>  
    </div>  
    <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-white uppercase tracking-wide mb-10">  
      {pricingData.heading} <span style="color: var(--color-primary);">{pricingData.headingAccent}</span>  
    </h2>  
  
    <!-- Pricing cards -->  
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">  
      {pricingData.plans.map((plan) => (  
        <div class={`group relative flex flex-col p-6 rounded-2xl border bg-card-gradient backdrop-blur-sm transition-all duration-300 ${plan.theme.border} hover:-translate-y-1 hover:shadow-card`}>  
          {"badge" in plan && plan.badge && (  
            <div class="absolute -top-px left-6">  
              <span class="inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-b-lg bg-cta-gradient text-white">  
                {plan.badge}  
              </span>  
            </div>  
          )}  
            
          <div class="flex items-start gap-4 mb-6">  
            <div class={`flex-shrink-0 p-3 rounded-xl bg-gradient-to-br ${plan.theme.color} border border-white/5`}>  
              <svg xmlns="http://www.w3.org/2000/svg" class={`w-6 h-6 ${plan.theme.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[plan.iconKey]} />  
            </div>  
            <div class="flex-1">  
              <p class={`text-xs font-mono font-medium mb-1 ${plan.theme.accent}`}>{plan.tagline}</p>  
              <h3 class="font-display font-bold text-xl text-white mb-2">{plan.name}</h3>  
              <p class="text-site-text-muted text-sm leading-relaxed">{plan.description}</p>  
            </div>  
          </div>  
  
          <div class="mb-6">  
            <span class="font-display font-bold text-4xl text-white">{plan.price}</span>  
            <span class="text-site-text-muted text-sm">{plan.period}</span>  
          </div>  
  
          <ul class="space-y-3 mb-6">  
            {plan.features.map((feature) => (  
              <li class="flex items-center gap-3 text-sm text-site-text">  
                <div class="w-5 h-5 rounded flex items-center justify-center flex-shrink-0" style="background: rgb(var(--primary-ch) / 0.1);">  
                  <svg class="w-3 h-3" style="color: var(--color-primary);" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" set:html={icons['check']} />  
                </div>  
                {feature}  
              </li>  
            ))}  
          </ul>  
  
          <a href={withBase('/contact')} class="mt-auto inline-flex items-center justify-center gap-2 px-6 py-3 text-white font-display font-semibold tracking-[2px] uppercase text-sm transition-all duration-300 hover:brightness-110" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">  
            Get Started  
          </a>  
        </div>  
      ))}  
    </div>  
  </div>  
</section>
