---
import projectsRaw from '@/data/projects/projects.json';
import siteData from '@/data/global/site.json';
import pageData from '@/data/projects/projects-page.json';
import { augmentProjectsWithImages, type ProjectEntry } from '../lib/fetchGitHub';
import { withBase } from '../lib/assetPath';
import { icons } from '../lib/icons';

const projectsData = await augmentProjectsWithImages(projectsRaw as ProjectEntry[]);
const featuredProjects = projectsData.filter((p: any) => p.featuredImage && typeof p.featuredImage === 'string' && p.featuredImage.trim() !== '');
---

<div class="site-band"></div>

<section id="featured-projects" aria-labelledby="featured-projects-heading" class="py-16 lg:py-24 relative overflow-hidden" style="background: linear-gradient(180deg, var(--bg-base) 0%, var(--bg-deep) 100%);">

  <!-- Screen-reader live region for slide changes -->
  <div aria-live="polite" aria-atomic="true" class="sr-only" id="slider-announce"></div>

  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgb(var(--primary-ch) / 0.025) 1px, transparent 1px), linear-gradient(90deg, rgb(var(--primary-ch) / 0.025) 1px, transparent 1px); background-size: 40px 40px;"></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-12">

    <!-- Section heading -->
    <div class="flex items-center gap-3 mb-3">
      <div class="h-px w-8" style="background: var(--color-primary);"></div>
      <span class="text-xs font-mono font-semibold tracking-[3px] uppercase" style="color: var(--color-primary);">{pageData.featuredEyebrow}</span>
    </div>
    <h2 id="featured-projects-heading" class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-white uppercase tracking-wide mb-12">
      {pageData.featuredHeading} <span style="color: var(--color-primary);">{pageData.featuredAccent}</span>
    </h2>

    <!-- Slider layout: frame left, info right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch">

      <!-- Retro terminal frame -->
      <div class="relative flex justify-center lg:justify-start">

        <!-- Outer glow -->
        <div class="absolute inset-0 pointer-events-none" style="border-radius: 8px; box-shadow: 0 0 60px rgb(var(--primary-ch) / 0.06);"></div>

        <div class="slider-frame w-full" style="max-width: 520px;">

          <!-- Title bar -->
          <div class="slider-titlebar">
            <div class="flex items-center gap-2">
              <div class="titlebar-dot" style="--dot-color: var(--bg-elevated);"></div>
              <div class="titlebar-dot" style="--dot-color: var(--bg-surface);"></div>
              <div class="titlebar-dot" style="--dot-color: var(--bg-surface);"></div>
            </div>
            <span class="titlebar-label font-mono">featured_projects/</span>
            <div class="flex items-center gap-2 ml-auto">
              <span id="slide-counter" class="font-mono text-xs" style="color: var(--color-primary);">01 / {String(featuredProjects.length).padStart(2, '0')}</span>
            </div>
          </div>

          <!-- Slide viewport -->
          <div class="slider-viewport" id="slider-viewport">
            <div class="slider-track" id="slider-track">
              {featuredProjects.map((project: any, i: number) => (
                <div class="slider-slide" data-index={i}>
                  <img
                    src={withBase(project.featuredImage)}
                    alt={project.title}
                    width="800"
                    height="500"
                    class="w-full h-full object-cover"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    fetchpriority={i === 0 ? 'high' : 'auto'}
                    decoding="async"
                  />
                  <!-- Overlay gradient -->
                  <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(4,5,7,0.9) 0%, rgba(4,5,7,0.3) 50%, transparent 100%);"></div>
                  <!-- Scanline effect -->
                  <div class="slider-scanlines" aria-hidden="true"></div>
                </div>
              ))}
            </div>

            <!-- Dot navigation -->
            <div class="slider-dots" id="slider-dots">
              {featuredProjects.map((_: any, i: number) => (
                <button
                  class={`slider-dot${i === 0 ? ' active' : ''}`}
                  data-dot={i}
                  aria-label={`Go to slide ${i + 1}`}
                  aria-pressed={i === 0 ? 'true' : 'false'}
                />
              ))}
            </div>

            <!-- Prev / Next -->
            <button class="slider-arrow slider-arrow-prev" id="slider-prev" aria-label="Previous project">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5" stroke-width="2.5" set:html={icons['chevron-left']} />
            </button>
            <button class="slider-arrow slider-arrow-next" id="slider-next" aria-label="Next project">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5" stroke-width="2.5" set:html={icons['chevron-right']} />
            </button>

          </div>

          <!-- Status bar -->
          <div class="slider-statusbar">
            <button id="autoplay-toggle" class="slider-autoplay-btn font-mono text-xs" aria-label="Pause autoplay">[ AUTOPLAY ]</button>
            <span class="font-mono text-xs" style="color: var(--color-primary);">{siteData.name.toUpperCase()}</span>
          </div>

        </div>
      </div>

      <!-- Project info panel -->
      <div class="relative">
      <div class="space-y-5 lg:absolute lg:inset-0 lg:flex lg:flex-col lg:justify-center" style="overflow: visible;">

        <!-- Category badge -->
        <div id="slide-category" class="inline-flex items-center gap-2">
          <span class="font-mono text-xs font-bold tracking-[2px] uppercase px-3 py-1 border" style="color: var(--color-primary); border-color: var(--color-primary); background: rgb(var(--primary-ch) / 0.08);">
            {featuredProjects[0]?.category}
          </span>
        </div>

        <!-- Title -->
        <h3 id="slide-title" class="font-display font-bold text-2xl sm:text-3xl text-white uppercase tracking-wide leading-tight">
          {featuredProjects[0]?.title}
        </h3>

        <!-- Company -->
        <p id="slide-company" class="font-mono text-xs tracking-widest uppercase" style="color: var(--color-text-dim);">
          {featuredProjects[0]?.company}
        </p>

        <!-- Divider -->
        <div class="site-band" style="max-width: 4rem;"></div>

        <!-- Description -->
        <p id="slide-description" class="text-site-text-muted text-base leading-relaxed">
          {featuredProjects[0]?.description}
        </p>

        <!-- Tags -->
        <div id="slide-tags" class="flex flex-wrap gap-2">
          {featuredProjects[0]?.tags.map((tag: string) => (
            <span class="px-2.5 py-1 text-xs font-mono border" style="border-color: var(--color-border); color: var(--color-text-muted); background: var(--bg-elevated);">
              {tag}
            </span>
          ))}
        </div>

        <!-- CTA -->
        {featuredProjects[0]?.link && (
          <div id="slide-cta">
            <a
              href={featuredProjects[0].link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-display font-semibold tracking-[2px] uppercase transition-all duration-300 hover:brightness-110"
              style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); color: var(--bg-base);"
            >
              View Project
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4" stroke-width="2.5" set:html={icons['external-link']} />
            </a>
          </div>
        )}

        <!-- "View all" link -->
        <p class="text-sm">
          <a href="#projects" class="slider-view-all-link hover:underline transition-colors">
            {pageData.viewAllLabel} ({projectsData.length} {pageData.viewAllUnit}) →
          </a>
        </p>

      </div>
      </div>
    </div>
  </div>
</section>

<div class="site-band"></div>

<script is:inline define:vars={{ featuredProjects }}>
  const track = document.getElementById('slider-track');
  const dots = document.querySelectorAll('.slider-dot');
  const prevBtn = document.getElementById('slider-prev');
  const nextBtn = document.getElementById('slider-next');
  const counter = document.getElementById('slide-counter');
  const slideTitle = document.getElementById('slide-title');
  const slideCompany = document.getElementById('slide-company');
  const slideDesc = document.getElementById('slide-description');
  const slideCat = document.getElementById('slide-category');
  const slideTags = document.getElementById('slide-tags');
  const slideCta = document.getElementById('slide-cta');
  const autoplayToggle = document.getElementById('autoplay-toggle');
  const announceEl = document.getElementById('slider-announce');

  let current = 0;
  const total = featuredProjects.length;
  let timer = null;
  let paused = false;

  function goTo(idx) {
    current = (idx + total) % total;
    if (track) track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.classList.toggle('active', i === current);
      d.setAttribute('aria-pressed', i === current ? 'true' : 'false');
    });
    if (counter) counter.textContent = `${String(current + 1).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;

    const p = featuredProjects[current];
    if (announceEl) announceEl.textContent = `Slide ${current + 1} of ${total}: ${p.title}`;
    if (slideTitle) slideTitle.textContent = p.title;
    if (slideCompany) slideCompany.textContent = p.company;
    if (slideDesc) slideDesc.textContent = p.description;
    if (slideCat) {
      slideCat.textContent = '';
      const catSpan = document.createElement('span');
      catSpan.className = 'font-mono text-xs font-bold tracking-[2px] uppercase px-3 py-1 border';
      catSpan.style.cssText = 'color:var(--color-primary);border-color:var(--color-primary);background:rgb(var(--primary-ch)/0.08);';
      catSpan.textContent = p.category;
      slideCat.appendChild(catSpan);
    }
    if (slideTags) {
      slideTags.textContent = '';
      p.tags.forEach(t => {
        const tagSpan = document.createElement('span');
        tagSpan.className = 'px-2.5 py-1 text-xs font-mono border';
        tagSpan.style.cssText = 'border-color:var(--color-border);color:var(--color-text-muted);background:var(--bg-elevated);';
        tagSpan.textContent = t;
        slideTags.appendChild(tagSpan);
      });
    }
    if (slideCta) {
      slideCta.textContent = '';
      if (p.link) {
        const label = p.link.includes('github.com') ? 'View on GitHub' : p.link.includes('gitlab') ? 'View on GitLab' : p.link.includes('blog') ? 'Read Post' : 'View Project';
        const a = document.createElement('a');
        a.href = p.link;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'inline-flex items-center gap-2 px-5 py-2.5 text-sm font-display font-semibold tracking-[2px] uppercase transition-all duration-300 hover:brightness-110';
        a.style.cssText = 'background:linear-gradient(135deg,var(--color-primary) 0%,var(--color-primary-dark) 100%);color:var(--bg-base);';
        a.textContent = label;
        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('stroke', 'currentColor');
        svg.setAttribute('viewBox', '0 0 24 24');
        svg.setAttribute('class', 'w-4 h-4');
        svg.setAttribute('stroke-width', '2.5');
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('d', 'M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25');
        svg.appendChild(path);
        a.appendChild(svg);
        slideCta.appendChild(a);
      }
    }
  }

  function startTimer() {
    clearInterval(timer);
    if (!paused) timer = setInterval(() => goTo(current + 1), 4500);
  }

  function setPaused(val) {
    paused = val;
    if (paused) {
      clearInterval(timer);
      if (autoplayToggle) {
        autoplayToggle.textContent = '[ PAUSED ]';
        autoplayToggle.setAttribute('aria-label', 'Resume autoplay');
        autoplayToggle.classList.add('is-paused');
      }
    } else {
      startTimer();
      if (autoplayToggle) {
        autoplayToggle.textContent = '[ AUTOPLAY ]';
        autoplayToggle.setAttribute('aria-label', 'Pause autoplay');
        autoplayToggle.classList.remove('is-paused');
      }
    }
  }

  autoplayToggle?.addEventListener('click', () => setPaused(!paused));

  prevBtn?.addEventListener('click', () => { goTo(current - 1); startTimer(); });
  nextBtn?.addEventListener('click', () => { goTo(current + 1); startTimer(); });
  dots.forEach(d => d.addEventListener('click', () => { goTo(parseInt(d.dataset.dot)); startTimer(); }));

  // Touch swipe
  let touchStartX = 0;
  const viewport = document.getElementById('slider-viewport');
  viewport?.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
  viewport?.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) { goTo(dx < 0 ? current + 1 : current - 1); startTimer(); }
  }, { passive: true });

  // Keyboard navigation — arrow keys when focus is within the slider
  const sliderRegion = document.getElementById('featured-projects');
  sliderRegion?.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); startTimer(); }
    if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); startTimer(); }
  });

  startTimer();
</script>

<style>
  .slider-frame {
    border: 1px solid var(--color-border);
    background: var(--bg-base);
    overflow: hidden;
  }

  .slider-titlebar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    background: var(--bg-deep);
    border-bottom: 1px solid var(--color-border);
    min-height: 36px;
  }

  .titlebar-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--dot-color);
    opacity: 0.8;
    flex-shrink: 0;
  }

  .titlebar-label {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    flex: 1;
    text-align: center;
  }

  .slider-viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-base);
  }

  .slider-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .slider-slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .slider-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  .slider-dots {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 6px;
    z-index: 10;
  }

  .slider-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: rgba(255,255,255,0.2);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .slider-dot.active {
    background: var(--color-primary);
    width: 20px;
    box-shadow: 0 0 8px rgb(var(--primary-ch) / 0.5);
  }

  .slider-dot:focus-visible,
  .slider-autoplay-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgb(var(--bg-base-ch) / 0.75);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .slider-arrow:hover {
    background: rgb(var(--primary-ch) / 0.15);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .slider-arrow-prev { left: 8px; }
  .slider-arrow-next { right: 8px; }

  .slider-statusbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.875rem;
    background: var(--bg-deep);
    border-top: 1px solid var(--color-border);
  }

  .slider-autoplay-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
    letter-spacing: inherit;
  }

  .slider-autoplay-btn:hover {
    color: var(--color-primary);
  }

  .slider-autoplay-btn.is-paused {
    color: var(--color-primary);
  }

  .slider-view-all-link {
    color: var(--color-text-dim);
  }
  .slider-view-all-link:hover,
  .slider-view-all-link:focus {
    color: var(--color-primary);
  }
</style>
