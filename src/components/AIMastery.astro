---
import aiDataRaw from '@/data/ai-mastery/ai-mastery.json';
import pageData from '@/data/ai-mastery/ai-mastery-page.json';
import { augmentProjectsWithImages, type ProjectEntry } from '../lib/fetchGitHub';
import { withBase } from '../lib/assetPath';
import { icons } from '../lib/icons';
import Modal from '@/components/Modal.astro';

interface Props {
  featuredOnly?: boolean;
}
const { featuredOnly = false } = Astro.props;

const allProjectsData = await augmentProjectsWithImages(aiDataRaw as ProjectEntry[], 'ai-mastery');
const projectsData = featuredOnly
  ? allProjectsData.filter(p => p.featuredImage)
  : allProjectsData;

const filters = pageData.filters;

const projectsForScript = projectsData.map((p) => ({
  ...p,
  featuredImage:   p.featuredImage   ? withBase(p.featuredImage)   : p.featuredImage,
  backgroundImage: p.backgroundImage ? withBase(p.backgroundImage) : p.backgroundImage,
  colorIcon:       p.colorIcon       ? withBase(p.colorIcon)       : p.colorIcon,
}));
---

<div class="site-band"></div>

<section id="projects" aria-labelledby="projects-heading" class="py-16 lg:py-24 relative" style="background: var(--bg-base);">

  <!-- Dot grid background -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgb(var(--primary-ch) / 0.07) 1px, transparent 1px); background-size: 28px 28px;"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Section heading -->
    <div class="flex items-center gap-3 mb-3">
      <div class="h-px w-8" style="background: var(--color-primary);"></div>
      <span class="text-xs font-mono font-semibold tracking-[3px] uppercase" style="color: var(--color-primary);">
        {featuredOnly ? pageData.featuredEyebrow : pageData.allEyebrow}
      </span>
    </div>
    <h2 id="projects-heading" class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl uppercase tracking-wide mb-10" style="color: var(--color-text);">
      {featuredOnly
        ? <>{pageData.featuredHeading} <span style="color: var(--color-primary);">{pageData.featuredAccent}</span></>
        : <>{pageData.allHeading} <span style="color: var(--color-primary);">{pageData.allAccent}</span></>}
    </h2>

    {featuredOnly && (
      <div class="flex mb-8">
        <a href={withBase('/ai-mastery')} class="portfolio-link inline-flex items-center gap-2 text-xs font-mono">
          View full portfolio →
        </a>
      </div>
    )}

    <!-- Filter bar -->
    <div class="project-filter-bar" style={featuredOnly ? 'display: none;' : ''}>
      {filters.map(f => (
        <button
          class="project-filter-btn font-mono text-xs font-semibold tracking-[1px] uppercase"
          data-filter={f.value}
          aria-pressed={f.value === 'all' ? 'true' : 'false'}
        >
          {f.label}
          <span class="project-filter-count" data-count={f.value}></span>
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projectsData.map((project, i) => (
        <div
          class={`project-card${project.backgroundImage ? ' has-bg' : ''}`}
          data-category={project.category}
          data-index={i}
          style={`--enter-delay: ${(i % 3) * 0.06}s;`}
          role="button"
          tabindex="0"
          aria-label={`Open details for ${project.title}`}
        >
          <!-- Float icon -->
          {project.colorIcon && (
            <div class="project-float-icon" aria-hidden="true">
              <img
                src={withBase(project.colorIcon)}
                alt=""
                width="42"
                height="42"
                class={`project-icon-img${project.colorIcon.includes('githubusercontent') ? ' project-icon-github' : ''}`}
                loading="lazy"
                decoding="async"
              />
            </div>
          )}

          <div class={`project-inner${project.backgroundImage ? ' has-bg-img' : ''}`}>

            <!-- Background image -->
            {project.backgroundImage && (
              <div class="project-bg-img" aria-hidden="true">
                <img src={withBase(project.backgroundImage)} alt="" width="600" height="400" loading="lazy" decoding="async" />
              </div>
            )}

            <!-- Body -->
            <div class="p-5 flex flex-col flex-1 relative z-10">
              <p class="project-company">{project.company}</p>
              <h3 class="project-title font-display font-bold text-lg uppercase tracking-wide mb-2 leading-snug">
                {project.title}
              </h3>
              <p class="project-desc text-sm leading-relaxed flex-1 mb-4">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {project.tags.map((tag: string) => (
                  <span class="project-tag font-mono">{tag}</span>
                ))}
              </div>
            </div>

            <!-- Footer -->
            <div class="project-footer relative z-10">
              <span class="project-cat-badge font-mono">{project.category}</span>
              {project.icon && icons[project.icon] && (
                <div class="project-heroicon shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                    stroke-width="1.5" stroke="currentColor" class="w-5 h-5"
                    set:html={icons[project.icon]} />
                </div>
              )}
              <span class="project-open-hint ml-auto">
                <span class="project-hint-text">open</span>
                <svg class="project-hint-arrow w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" set:html={icons['external-link']} />
              </span>
            </div>

          </div>
        </div>
      ))}
    </div>

    <p id="projects-empty" class="hidden text-center text-sm mt-12 font-mono" style="color: var(--color-text-muted);">
      No projects in this category yet.
    </p>

  </div>
</section>

<Modal id="project-modal">
  <a id="project-modal-link" href="#" target="_blank" rel="noopener noreferrer" class="modal-cta">
    <span id="project-modal-link-text" class="font-display uppercase tracking-[2px] font-semibold">View Project</span>
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" set:html={icons['external-link']} />
  </a>
  <p id="project-modal-no-link" class="modal-no-link hidden font-mono">Private / No public link available.</p>
</Modal>

<div class="site-band"></div>

<!-- Project data for the client script — not executable JS, just data. -->
<script is:inline type="application/json" id="projects-data" set:html={JSON.stringify(projectsForScript).replace(/<\/script>/gi, '<\\/script>')} />

<script>
  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('projects-grid')) return;

    const el = document.getElementById('projects-data') as HTMLElement | null;
    const projects: {
      title: string; company: string; category: string; description: string;
      tags: string[]; link: string; icon: string;
      featuredImage?: string; backgroundImage?: string; colorIcon?: string;
    }[] = el ? JSON.parse(el.textContent ?? '[]') : [];

    // ── Filter ────────────────────────────────────────────────
    const filterBtns = document.querySelectorAll<HTMLElement>('.project-filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.project-card[data-category]');
    const empty = document.getElementById('projects-empty');
    let activeFilter = 'all';

    document.querySelectorAll<HTMLElement>('.project-filter-count').forEach(el => {
      const cat = el.dataset.count;
      const n = cat === 'all' ? cards.length : [...cards].filter(c => c.dataset.category === cat).length;
      el.textContent = `${n}`;
    });

    function setFilterActive(btn: HTMLElement, on: boolean) {
      if (on) {
        btn.style.color = 'var(--color-primary)';
        btn.style.borderColor = 'var(--color-primary)';
        btn.style.background = 'rgb(var(--primary-ch) / 0.08)';
        btn.setAttribute('aria-pressed', 'true');
        const cnt = btn.querySelector<HTMLElement>('.project-filter-count');
        if (cnt) { cnt.style.color = 'var(--color-primary)'; cnt.style.background = 'rgb(var(--primary-ch) / 0.15)'; }
      } else {
        btn.style.color = '';
        btn.style.borderColor = '';
        btn.style.background = '';
        btn.setAttribute('aria-pressed', 'false');
        const cnt = btn.querySelector<HTMLElement>('.project-filter-count');
        if (cnt) { cnt.style.color = ''; cnt.style.background = ''; }
      }
    }

    function applyFilter(filter: string) {
      if (filter === activeFilter) return;
      activeFilter = filter;
      filterBtns.forEach(b => setFilterActive(b, b.dataset.filter === filter));
      let visible = 0;
      cards.forEach(card => {
        const matches = filter === 'all' || card.dataset.category === filter;
        card.classList.remove('project-enter');
        if (!matches) {
          card.classList.add('project-hidden');
        } else {
          card.classList.remove('project-hidden');
          card.style.setProperty('--enter-delay', `${visible * 0.045}s`);
          void card.offsetWidth;
          card.classList.add('project-enter');
          visible++;
        }
      });
      if (empty) empty.classList.toggle('hidden', visible > 0);
    }

    filterBtns.forEach(btn => btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all')));

    const allBtn = document.querySelector<HTMLElement>('[data-filter="all"]');
    if (allBtn) setFilterActive(allBtn, true);

    // ── Modal ─────────────────────────────────────────────────
    function openModal(idx: number, trigger?: HTMLElement) {
      const p = projects[idx];
      if (!p) return;

      // Record the trigger so the modal can return focus on close (WCAG 2.4.3)
      if (trigger && (window as any).__setModalOpener) (window as any).__setModalOpener(trigger);

      const modal    = document.getElementById('project-modal')!;
      const modalBox = document.getElementById('project-modal-box')!;

      const img = p.featuredImage || p.backgroundImage || null;
      const safeImg = img && /^(https?:\/\/|\/)[^\s'"()]+$/.test(img) ? img : null;
      const hero = document.getElementById('project-modal-hero') as HTMLElement;
      if (safeImg) {
        hero.style.backgroundImage = `url("${safeImg}")`;
        hero.style.display = '';
      } else {
        hero.style.backgroundImage = '';
        hero.style.display = 'none';
      }

      (document.getElementById('project-modal-cat')    as HTMLElement).textContent = p.category;
      (document.getElementById('project-modal-title')  as HTMLElement).textContent = p.title;
      (document.getElementById('project-modal-subtitle') as HTMLElement).textContent = p.company;
      (document.getElementById('project-modal-desc')   as HTMLElement).textContent = p.description;

      const tagsEl  = document.getElementById('project-modal-tags')!;
      const tagFrag = document.createDocumentFragment();
      p.tags.forEach((t: string) => {
        const span = document.createElement('span');
        span.className = 'modal-tag font-mono';
        span.textContent = t;
        tagFrag.appendChild(span);
      });
      tagsEl.replaceChildren(tagFrag);

      const modalLink   = document.getElementById('project-modal-link') as HTMLAnchorElement;
      const modalLinkTx = document.getElementById('project-modal-link-text') as HTMLElement;
      const modalNoLink = document.getElementById('project-modal-no-link') as HTMLElement;

      if (p.link) {
        modalLink.href = p.link;
        if (p.link.includes('github.com'))  modalLinkTx.textContent = 'View on GitHub';
        else if (p.link.includes('gitlab')) modalLinkTx.textContent = 'View on GitLab';
        else if (p.link.includes('blog'))   modalLinkTx.textContent = 'Read the Post';
        else                                modalLinkTx.textContent = 'View Project';
        modalLink.classList.remove('hidden');
        modalNoLink.classList.add('hidden');
      } else {
        modalLink.classList.add('hidden');
        modalNoLink.classList.remove('hidden');
      }

      modal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      void modalBox.offsetWidth;
      modal.classList.add('modal-open');
      (document.getElementById('project-modal-close') as HTMLElement)?.focus();
    }

    cards.forEach(card => {
      card.addEventListener('click', () => openModal(parseInt(card.dataset.index ?? '0', 10), card));
      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openModal(parseInt(card.dataset.index ?? '0', 10), card);
        }
      });
    });
  });
</script>

<style is:global>

  /* ═══════════════════════════════════════════════════════════
     PORTFOLIO LINK
  ═══════════════════════════════════════════════════════════ */
  .portfolio-link {
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .portfolio-link:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
  }

  /* ═══════════════════════════════════════════════════════════
     FILTER BAR
  ═══════════════════════════════════════════════════════════ */
  .project-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .project-filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-dim);
    background: var(--bg-deep);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .project-filter-btn:hover {
    color: var(--color-text) !important;
    border-color: var(--color-primary) !important;
  }

  .project-filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    font-size: 0.6rem;
    font-weight: 700;
    background: var(--bg-elevated);
    color: var(--color-text-muted);
    border-radius: 2px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  /* ═══════════════════════════════════════════════════════════
     CARD VISIBILITY / ANIMATION
  ═══════════════════════════════════════════════════════════ */
  .project-card {
    position: relative;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .project-card.project-hidden { display: none; }
  .project-card.project-enter {
    animation: project-card-enter 0.38s cubic-bezier(0.22, 1, 0.36, 1) var(--enter-delay, 0s) both;
  }
  @keyframes project-card-enter {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ═══════════════════════════════════════════════════════════
     FLOAT ICON
  ═══════════════════════════════════════════════════════════ */
  .project-float-icon {
    position: absolute;
    top: -13px;
    right: 14px;
    z-index: 20;
    width: 42px;
    height: 42px;
    background: var(--bg-deep);
    border: 1px solid var(--color-border);
    box-shadow: 0 4px 14px rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7px;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .project-card:hover .project-float-icon {
    transform: translateY(-4px) scale(1.1);
    border-color: var(--color-primary);
    box-shadow: 0 8px 24px rgba(0,0,0,0.4), 0 0 14px rgb(var(--primary-ch) / 0.18);
  }
  .project-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .project-icon-github {
    filter: invert(1) brightness(0.85);
  }
  html.light-mode .project-icon-github {
    filter: invert(0) brightness(0.5);
  }

  /* ═══════════════════════════════════════════════════════════
     CARD SHELL
  ═══════════════════════════════════════════════════════════ */
  .project-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--color-border);
    background: var(--bg-deep);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .project-card:hover .project-inner {
    transform: translateY(-4px);
    border-color: var(--color-primary);
    box-shadow: 0 16px 44px rgba(0,0,0,0.35), 0 0 0 1px rgb(var(--primary-ch) / 0.12), 0 0 20px rgb(var(--primary-ch) / 0.06);
  }
  .project-inner.has-bg-img {
    background: transparent;
  }

  /* ═══════════════════════════════════════════════════════════
     BACKGROUND IMAGE
  ═══════════════════════════════════════════════════════════ */
  .project-bg-img {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .project-bg-img::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(155deg, rgba(4,5,7,0.42) 0%, rgba(4,5,7,0.68) 100%);
    transition: background 0.5s ease;
  }
  .project-card:hover .project-bg-img::after {
    background: linear-gradient(155deg, rgba(4,5,7,0.28) 0%, rgba(4,5,7,0.54) 100%);
  }
  .project-bg-img img {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    object-fit: cover;
    filter: blur(24px) saturate(2) brightness(0.42) grayscale(0.2);
    transition: filter 0.5s ease;
  }
  .project-card:hover .project-bg-img img {
    filter: blur(18px) saturate(2.4) brightness(0.54) grayscale(0.2);
  }

  /* ═══════════════════════════════════════════════════════════
     CARD TEXT
  ═══════════════════════════════════════════════════════════ */
  .project-company {
    font-size: 0.65rem;
    font-family: ui-monospace, monospace;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .project-title {
    color: var(--color-text);
    transition: color 0.3s ease;
  }
  .project-card:hover .project-title { color: var(--color-primary); }

  .project-desc {
    color: var(--color-text-dim);
  }
  .has-bg .project-desc {
    color: rgb(var(--text-muted-ch) / 0.85);
  }

  /* ═══════════════════════════════════════════════════════════
     TAGS
  ═══════════════════════════════════════════════════════════ */
  .project-tag {
    font-size: 0.65rem;
    letter-spacing: 0.03em;
    color: var(--color-text-dim);
    background: var(--bg-base);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.55rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .project-card:hover .project-tag {
    color: var(--color-text-muted);
    border-color: var(--color-border-hover);
  }
  .has-bg .project-tag {
    background: rgba(4,5,7,0.55);
    color: rgba(154, 163, 174, 0.85);
  }

  /* ═══════════════════════════════════════════════════════════
     FOOTER BAR
  ═══════════════════════════════════════════════════════════ */
  .project-footer {
    border-top: 1px solid var(--color-border);
    padding: 0.6rem 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: rgba(0,0,0,0.12);
    transition: border-top-color 0.3s ease, background 0.3s ease;
  }
  .project-card:hover .project-footer {
    border-top-color: rgb(var(--primary-ch) / 0.25);
    background: rgb(var(--primary-ch) / 0.05);
  }
  .has-bg .project-footer {
    background: rgba(0,0,0,0.38);
    border-top-color: rgba(255,255,255,0.08);
  }
  .has-bg:hover .project-inner .project-footer {
    background: rgb(var(--primary-ch) / 0.18);
    border-top-color: rgb(var(--primary-ch) / 0.3);
  }

  /* ── Category badge ── */
  .project-cat-badge {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: rgb(var(--primary-ch) / 0.04);
    border: 1px solid rgb(var(--primary-ch) / 0.1);
    padding: 0.2rem 0.6rem;
    transition: color 0.3s ease, background 0.3s ease, border-color 0.3s ease;
  }
  .project-card:hover .project-cat-badge {
    color: var(--color-primary);
    background: rgb(var(--primary-ch) / 0.1);
    border-color: rgb(var(--primary-ch) / 0.3);
  }

  /* ── Heroicon ── */
  .project-heroicon {
    color: rgb(var(--primary-ch) / 0.35);
    transition: color 0.3s ease;
  }
  .project-card:hover .project-heroicon { color: rgb(var(--primary-ch) / 0.7); }
  .project-heroicon svg { transition: transform 0.3s ease, opacity 0.3s ease; }
  .project-card:hover .project-heroicon svg { transform: translateY(60px); opacity: 0; }

  /* ── Open hint ── */
  .project-open-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.65rem;
    font-family: ui-monospace, monospace;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color 0.3s ease, gap 0.3s ease;
    user-select: none;
  }
  .project-hint-arrow {
    opacity: 0.4;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  }
  .project-card:hover .project-open-hint { color: var(--color-primary); gap: 0.5rem; }
  .project-card:hover .project-hint-arrow { transform: translate(2px, -2px); opacity: 1; }

  /* ═══════════════════════════════════════════════════════════
     LIGHT MODE OVERRIDES
  ═══════════════════════════════════════════════════════════ */
  html.light-mode .project-inner {
    background: var(--bg-elevated);
    border-color: var(--color-border);
  }
  html.light-mode .project-card:hover .project-inner {
    box-shadow: 0 16px 40px rgba(0,0,0,0.1), 0 0 0 1px rgb(var(--primary-ch) / 0.2);
  }

  html.light-mode .project-card.has-bg .project-bg-img {
    filter: invert(0.88) saturate(1.4) brightness(1.1);
  }
  html.light-mode .project-card.has-bg:hover .project-bg-img {
    filter: invert(0.88) saturate(1.7) brightness(1.2);
  }
  html.light-mode .project-card.has-bg .project-bg-img img {
    filter: blur(24px) saturate(1.8) brightness(0.72);
  }
  html.light-mode .project-card.has-bg:hover .project-bg-img img {
    filter: blur(18px) saturate(2.1) brightness(0.82);
  }
  html.light-mode .project-card.has-bg .project-bg-img::after { display: none; }

  html.light-mode .project-inner.has-bg-img {
    background: rgba(255, 255, 255, 0.52);
  }

  html.light-mode .project-card.has-bg .project-title  { color: #0f172a; }
