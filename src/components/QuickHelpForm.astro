---
import siteData from '@/data/global/site.json';
import qhData from '@/data/contact/quickhelp.json';
import { qhIcons, icons } from '../lib/icons';
---

<section id="quick-help" aria-labelledby="quick-help-heading" class="relative py-20 px-6 lg:px-12" style="background: var(--bg-deep); border-top: 1px solid var(--bg-raised);">
  <!-- Screen-reader live region for form status -->
  <div id="qh-announce" aria-live="assertive" aria-atomic="true" class="sr-only"></div>

  <div class="max-w-3xl mx-auto">

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px w-8" style="background: var(--color-primary);"></div>
        <span class="text-xs font-mono font-semibold tracking-[3px] uppercase" style="color: var(--color-primary);">{qhData.sectionLabel}</span>
      </div>
      <h2 id="quick-help-heading" class="font-display font-bold text-4xl sm:text-5xl text-site-text uppercase tracking-wide leading-tight mb-3">
        {qhData.heading}
      </h2>
      <p class="text-site-text-muted text-lg leading-relaxed max-w-xl">
        {qhData.blurb}
      </p>
    </div>

    <!-- Step progress -->
    <div class="flex items-center gap-3 mb-8" id="qh-progress" role="list" aria-label="Form steps">
      <div class="flex items-center gap-2" role="listitem">
        <div id="dot-1" class="w-2 h-2 rounded-full transition-colors" style="background: var(--color-primary);" aria-hidden="true"></div>
        <span id="label-1" class="text-xs font-mono uppercase tracking-wider transition-colors" style="color: var(--color-primary);" aria-current="step">{qhData.stepLabels[0]}</span>
      </div>
      <div class="h-px flex-1" style="background: var(--bg-raised);" aria-hidden="true"></div>
      <div class="flex items-center gap-2" role="listitem">
        <div id="dot-2" class="w-2 h-2 rounded-full transition-colors" style="background: var(--color-border-alt);" aria-hidden="true"></div>
        <span id="label-2" class="text-xs font-mono uppercase tracking-wider transition-colors text-site-muted">{qhData.stepLabels[1]}</span>
      </div>
    </div>

    <!-- Quick Help form — submitted via Web3Forms -->
    <form
      id="qh-form"
      class="space-y-6"
      novalidate
    >
      <input type="hidden" name="service" id="qh-service-value" />
      <input type="checkbox" name="botcheck" class="hidden" aria-hidden="true" tabindex="-1" />

      <!-- ── Step 1: Service picker ── -->
      <div id="qh-step-1">
        <fieldset class="border-0 p-0 m-0 min-w-0">
          <legend class="sr-only">Select a service</legend>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6" id="qh-picker">
            {qhData.services.map((svc) => (
              <button type="button" data-service={svc.serviceValue} aria-pressed="false" class="qh-pick group flex flex-col items-center gap-3 p-5 text-center border transition-all duration-150 hover:border-site-green" style="background: var(--bg-elevated); border-color: var(--bg-raised);">
                <div class="qh-icon-wrap w-12 h-12 rounded-full flex items-center justify-center transition-colors" style="background: var(--bg-raised);">
                  <span aria-hidden="true" set:html={qhIcons[svc.iconKey]} />
                </div>
                <div>
                  <div class="text-sm font-bold text-site-text">{svc.label}</div>
                  <div class="text-xs text-site-muted mt-0.5">{svc.subLabel}</div>
                </div>
              </button>
            ))}
          </div>
        </fieldset>

        <!-- Next button (disabled until selection) -->
        <button
          type="button"
          id="qh-next"
          disabled
          class="flex items-center gap-2 px-8 py-4 font-display font-bold tracking-[2px] uppercase text-white transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed"
          style="background: var(--color-primary); font-size: 0.9rem;"
          onclick="qhGoToStep2()"
        >
          {qhData.buttons.next}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" set:html={icons['arrow-right']} />
        </button>
      </div>

      <!-- ── Step 2: Name + Email ── -->
      <div id="qh-step-2" class="hidden space-y-4">

        <!-- Selected service pill -->
        <div class="flex items-center gap-3 mb-2">
          <button type="button" onclick="qhGoToStep1()" class="flex items-center gap-1.5 text-xs font-mono text-site-muted hover:text-site-text transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" set:html={icons['arrow-back']} />
            {qhData.buttons.back}
          </button>
          <div class="h-4 w-px" style="background: var(--color-border-alt);"></div>
          <span id="qh-service-label" class="text-xs font-mono font-semibold px-2.5 py-1 uppercase tracking-wider" style="background: rgb(var(--primary-ch) / 0.12); color: var(--color-primary); border: 1px solid rgb(var(--primary-ch) / 0.25);"></span>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="qh-name" class="block text-xs font-mono font-medium text-site-muted mb-1.5 uppercase tracking-wider">{qhData.formLabels.name}</label>
            <input
              id="qh-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              aria-required="true"
              aria-describedby="qh-name-error"
              placeholder={qhData.formLabels.namePlaceholder}
              class="w-full px-4 py-3 text-site-text placeholder-site-muted text-sm focus:outline-none transition-colors"
              style="background: var(--bg-elevated); border: 1px solid var(--bg-raised);"
            />
            <p id="qh-name-error" class="qh-field-error hidden mt-1 text-xs font-mono" style="color: var(--color-error);" aria-live="polite" role="alert">
              Please enter your name.
            </p>
          </div>
          <div>
            <label for="qh-email" class="block text-xs font-mono font-medium text-site-muted mb-1.5 uppercase tracking-wider">{qhData.formLabels.email}</label>
            <input
              id="qh-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              aria-required="true"
              aria-describedby="qh-email-error"
              placeholder={qhData.formLabels.emailPlaceholder}
              class="w-full px-4 py-3 text-site-text placeholder-site-muted text-sm focus:outline-none transition-colors"
              style="background: var(--bg-elevated); border: 1px solid var(--bg-raised);"
            />
            <p id="qh-email-error" class="qh-field-error hidden mt-1 text-xs font-mono" style="color: var(--color-error);" aria-live="polite" role="alert">
              Please enter a valid email address.
            </p>
          </div>
        </div>

        <div class="flex items-center gap-6 pt-2">
          <button
            type="submit"
            class="flex items-center gap-2 px-8 py-4 font-display font-bold tracking-[2px] uppercase text-white transition-all duration-200 hover:brightness-110"
            style="background: var(--color-primary); font-size: 0.9rem;"
          >
            {qhData.buttons.submit}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" set:html={icons['arrow-right']} />
          </button>
          <p class="text-xs text-site-muted font-mono">{qhData.footerNote}</p>
        </div>
      </div>

    </form>

    <!-- ── Step 3: Success ── -->
    <div id="qh-step-3" class="hidden py-10 text-center">
      <div class="inline-flex items-center justify-center w-14 h-14 rounded-full mb-5" style="background: rgb(var(--primary-ch) / 0.12); border: 1px solid rgb(var(--primary-ch) / 0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="2.5" style="stroke: var(--color-primary);">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h3 class="font-display font-bold text-3xl text-site-text uppercase tracking-wide mb-3">{qhData.successTitle}</h3>
      <p class="text-site-text-muted text-lg max-w-md mx-auto">
        {qhData.successMessage}
      </p>
    </div>

  </div>
</section>

<style>
  .qh-field-error { display: block; }
  .qh-field-error.hidden { display: none; }

  .qh-pick.selected {
    border-color: var(--color-primary) !important;
    background: rgb(var(--primary-ch) / 0.07) !important;
  }
  .qh-pick.selected .qh-icon-wrap {
    background: rgb(var(--primary-ch) / 0.15) !important;
  }
  .qh-pick.selected svg path,
  .qh-pick.selected svg circle,
  .qh-pick.selected svg rect {
    stroke: var(--color-primary);
  }
  .qh-pick.selected svg circle[fill] {
    fill: var(--color-primary);
  }
</style>

<script is:inline define:vars={{ web3formsKey: siteData.web3formsKey }}>
  // ── State ──
  let selectedService = '';

  // ── Elements ──
  const picks = document.querySelectorAll('.qh-pick');
  const nextBtn = document.getElementById('qh-next');
  const step1 = document.getElementById('qh-step-1');
  const step2 = document.getElementById('qh-step-2');
  const step3 = document.getElementById('qh-step-3');
  const serviceValue = document.getElementById('qh-service-value');
  const serviceLabel = document.getElementById('qh-service-label');
  const dot2 = document.getElementById('dot-2');
  const label2 = document.getElementById('label-2');
  const form = document.getElementById('qh-form');

  // ── Pick a service ──
  picks.forEach(btn => {
    btn.addEventListener('click', () => {
      picks.forEach(p => { p.classList.remove('selected'); p.setAttribute('aria-pressed', 'false'); });
      btn.classList.add('selected');
      btn.setAttribute('aria-pressed', 'true');
      selectedService = btn.dataset.service || '';
      if (nextBtn) nextBtn.disabled = false;
    });
  });

  // ── Go to step 2 ──
  window.qhGoToStep2 = function () {
    if (!selectedService) return;
    if (serviceValue) serviceValue.value = selectedService;
    if (serviceLabel) serviceLabel.textContent = selectedService;
    if (step1) step1.classList.add('hidden');
    if (step2) step2.classList.remove('hidden');
    if (dot2) dot2.style.background = 'var(--color-primary)';
    if (label2) { label2.style.color = 'var(--color-primary)'; label2.setAttribute('aria-current', 'step'); }
    const label1 = document.getElementById('label-1');
    if (label1) label1.removeAttribute('aria-current');
    document.getElementById('qh-name')?.focus();
  };

  // ── Back to step 1 ──
  window.qhGoToStep1 = function () {
    if (step2) step2.classList.add('hidden');
    if (step1) step1.classList.remove('hidden');
    if (dot2) dot2.style.background = 'var(--color-border-alt)';
    if (label2) { label2.style.color = ''; label2.removeAttribute('aria-current'); }
    const label1 = document.getElementById('label-1');
    if (label1) label1.setAttribute('aria-current', 'step');
  };

  // ── Helper: show/clear field errors ──
  function showFieldError(inputEl, errorEl) {
    inputEl.style.borderColor = 'var(--color-error)';
    inputEl.setAttribute('aria-invalid', 'true');
    errorEl?.classList.remove('hidden');
  }
  function clearFieldError(inputEl, errorEl) {
    inputEl.style.borderColor = '';
    inputEl.removeAttribute('aria-invalid');
    errorEl?.classList.add('hidden');
  }

  // ── Submit ──
  if (form) form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameEl = document.getElementById('qh-name');
    const emailEl = document.getElementById('qh-email');
    const nameError = document.getElementById('qh-name-error');
    const emailError = document.getElementById('qh-email-error');
    const announce = document.getElementById('qh-announce');

    let valid = true;
    clearFieldError(nameEl, nameError);
    clearFieldError(emailEl, emailError);

    if (!nameEl.value.trim()) { showFieldError(nameEl, nameError); nameEl.focus(); valid = false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
      showFieldError(emailEl, emailError);
      if (valid) emailEl.focus(); // only move focus if name was valid
      valid = false;
    }
    if (!valid) return;

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          access_key: web3formsKey,
          subject:    'Quick Help Form',
          name:       nameEl.value.trim(),
          email:      emailEl.value.trim(),
          service:    selectedService,
          botcheck:   '',
        }),
      });
      const result = await res.json();
      if (!result.success) {
        console.error('[QuickHelp] Web3Forms error:', result.message);
      }
    } catch (err) {
      console.error('[QuickHelp] Submit failed:', err);
    }

    if (step2) step2.classList.add('hidden');
    const progress = document.getElementById('qh-progress');
    if (progress) progress.classList.add('hidden');
    if (step3) {
      step3.classList.remove('hidden');
      // Move focus into the success message so screen readers announce it
      const successHeading = step3.querySelector('h3');
      successHeading?.focus ? successHeading.setAttribute('tabindex', '-1') : null;
      successHeading?.focus();
    }
    if (announce) announce.textContent = 'Your message was sent. We will be in touch shortly.';
  });
</script>
